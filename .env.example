# Nuntia Configuration
# Copy to .env and fill in values

# Telegram Bot API token from @BotFather (required)
TELEGRAM_BOT_TOKEN=

# Enable WhatsApp adapter (default: false)
WHATSAPP_ENABLED=false

# Comma-separated whitelist of allowed chat IDs (required)
# For groups, use the group chat ID
ALLOWED_CHAT_IDS=

# Root directory for project workspaces (default: ./workspaces)
WORKSPACE_ROOT=./workspaces

# Path to the opencode binary (default: opencode)
OPENCODE_BIN=opencode

# Max execution time per OpenCode task in ms (default: 600000 = 10 min)
TASK_TIMEOUT_MS=600000

# 32-byte hex key for API key encryption (required)
# Generate with: openssl rand -hex 32
MASTER_KEY=

# Default OpenCode model name
DEFAULT_MODEL=claude-sonnet-4-20250514

# Logging level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# Optional Git remote URL for /push command (leave empty for local only)
GIT_REMOTE_URL=

# Git commit author info
GIT_USER_NAME=Nuntia
GIT_USER_EMAIL=bridge@localhost

# Maximum file upload size in MB (default: 50)
MAX_UPLOAD_SIZE_MB=50
